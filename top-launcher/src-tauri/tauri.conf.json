{
  "productName": "AppPanell",
  "version": "1.2.30",
  "identifier": "com.top.launcher.app",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Top Launcher",
        "width": 600,
        "height": 90,
        "resizable": false,
        "dragDropEnabled": true,

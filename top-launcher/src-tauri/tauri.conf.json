      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256"
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/Atoryx1s/AppPanell/releases/latest/download/latest.json"
      ],
      "pubkey": "RWQLE46PYpSximyxhGT86I15rvqz+6Q/vpnyK68SvRYbnVKwVj6iSdyc"
    }
